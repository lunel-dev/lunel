{
  "name": "lunel",
  "private": true,
  "scripts": {
    "remote:start": "pwsh -NoProfile -File ./scripts/remote-cli.ps1 start",
    "remote:window": "pwsh -NoProfile -File ./scripts/remote-cli.ps1 run-window",
    "remote:status": "pwsh -NoProfile -File ./scripts/remote-cli.ps1 status",
    "remote:stop": "pwsh -NoProfile -File ./scripts/remote-cli.ps1 stop",
    "remote:restart": "pwsh -NoProfile -File ./scripts/remote-cli.ps1 restart",
    "remote:ensure": "pwsh -NoProfile -File ./scripts/remote-cli.ps1 ensure",
    "remote:autostart:install": "pwsh -NoProfile -File ./scripts/install-remote-cli-autostart.ps1 install-logon",
    "remote:autostart:status": "pwsh -NoProfile -File ./scripts/install-remote-cli-autostart.ps1 status",
    "remote:autostart:remove": "pwsh -NoProfile -File ./scripts/install-remote-cli-autostart.ps1 remove-logon",
    "remote:boot:install": "pwsh -NoProfile -File ./scripts/install-remote-cli-autostart.ps1 install-boot-elevated",
    "remote:boot:remove": "pwsh -NoProfile -File ./scripts/install-remote-cli-autostart.ps1 remove-boot",
    "local:env": "pwsh -NoProfile -File ./scripts/local-env.ps1 show",
    "local:start": "pwsh -NoProfile -File ./scripts/local-dev.ps1 start",
    "local:start:fresh": "pwsh -NoProfile -File ./scripts/local-dev.ps1 start -FreshManager",
    "local:status": "pwsh -NoProfile -File ./scripts/local-dev.ps1 status",
    "local:stop": "pwsh -NoProfile -File ./scripts/local-dev.ps1 stop",
    "local:restart": "pwsh -NoProfile -File ./scripts/local-dev.ps1 restart",
    "local:lan:env": "pwsh -NoProfile -File ./scripts/local-env.ps1 show -HostAddress auto",
    "local:lan:start": "pwsh -NoProfile -File ./scripts/local-dev.ps1 start -HostAddress auto",
    "local:lan:start:fresh": "pwsh -NoProfile -File ./scripts/local-dev.ps1 start -HostAddress auto -FreshManager",
    "local:lan:status": "pwsh -NoProfile -File ./scripts/local-dev.ps1 status -HostAddress auto",
    "local:lan:stop": "pwsh -NoProfile -File ./scripts/local-dev.ps1 stop -HostAddress auto",
    "local:lan:firewall:install": "pwsh -NoProfile -File ./scripts/configure-local-lan-firewall.ps1 install",
    "local:lan:firewall:status": "pwsh -NoProfile -File ./scripts/configure-local-lan-firewall.ps1 status",
    "local:lan:firewall:remove": "pwsh -NoProfile -File ./scripts/configure-local-lan-firewall.ps1 remove",
    "local:shortcuts:install": "pwsh -NoProfile -File ./scripts/install-local-shortcuts.ps1 install",
    "local:shortcuts:list": "pwsh -NoProfile -File ./scripts/install-local-shortcuts.ps1 list",
    "local:shortcuts:remove": "pwsh -NoProfile -File ./scripts/install-local-shortcuts.ps1 remove",
    "local:cli:dev": "pwsh -NoProfile -File ./scripts/local-env.ps1 cli-exec -CommandLine 'npm run dev'",
    "local:cli:window": "pwsh -NoProfile -File ./scripts/local-env.ps1 cli-run-window",
    "local:cli:shell": "pwsh -NoProfile -File ./scripts/local-env.ps1 cli-shell",
    "local:lan:cli:window": "pwsh -NoProfile -File ./scripts/local-env.ps1 cli-run-window -HostAddress auto",
    "local:app:start": "pwsh -NoProfile -File ./scripts/local-env.ps1 app-exec -CommandLine 'npm run start'",
    "local:app:window": "pwsh -NoProfile -File ./scripts/local-env.ps1 app-run-window",
    "local:app:shell": "pwsh -NoProfile -File ./scripts/local-env.ps1 app-shell",
    "local:lan:app:start": "pwsh -NoProfile -File ./scripts/local-env.ps1 app-exec -HostAddress auto -CommandLine 'npm run start'",
    "local:lan:app:window": "pwsh -NoProfile -File ./scripts/local-env.ps1 app-run-window -HostAddress auto",
    "check:manager": "npm --prefix manager run check",
    "check:proxy": "npm --prefix proxy run check",
    "check:servers": "npm --prefix manager run check && npm --prefix proxy run check"
  }
}
